# -----------------------------------------------------------------------------
# DevOps Starter Kit local configuration
# Copy this file to .env, then run: make setup
# The defaults run the public demo from this repository.
# Change the values below when you are ready to use your own repo/image.
# -----------------------------------------------------------------------------

# Project/application identity
PROJECT_NAME=devops-starter-kit
APP_NAME=starter-app
APP_NAMESPACE=starter-app

# Git repository watched by ArgoCD
# Leave blank to use this clone's git remote origin.
GIT_REPO_URL=
GIT_TARGET_REVISION=main
HELM_CHART_PATH=helm/starter-app
HELM_RELEASE_NAME=starter-app

# DockerHub image used by GitHub Actions and ArgoCD
DOCKERHUB_USERNAME=axthithya
DOCKER_IMAGE_NAME=devops-starter-kit
IMAGE_TAG=latest
# Optional full image repository override. Leave blank to use DOCKERHUB_USERNAME/DOCKER_IMAGE_NAME.
IMAGE_REPOSITORY=

# Spring Boot container/service settings
REPLICA_COUNT=1
CONTAINER_PORT=8080
SERVICE_TYPE=NodePort
SERVICE_PORT=80
# Leave blank to let Kubernetes choose a free NodePort. Example: NODE_PORT=30080
NODE_PORT=

# Minikube settings
MINIKUBE_PROFILE=devops-starter-kit
MINIKUBE_DRIVER=docker
MINIKUBE_CPUS=2
MINIKUBE_MEMORY=4096

# ArgoCD settings
ARGOCD_NAMESPACE=argocd
ARGOCD_APP_NAME=starter-app
ARGOCD_PROJECT=default
ARGOCD_INSTALL_MANIFEST=https://raw.githubusercontent.com/argoproj/argo-cd/stable/manifests/install.yaml

# SonarCloud project identity
# Optional for local setup. Required only when enabling SonarCloud in CI.
SONAR_ORGANIZATION=your-sonarcloud-organization
SONAR_PROJECT_KEY=your-sonarcloud-project-key
SONAR_HOST_URL=https://sonarcloud.io

# Toolchain
JAVA_VERSION=21
